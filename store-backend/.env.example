# Store backend environment variables
PORT=3001

# Flutterwave secret key — get from https://dashboard.flutterwave.com/settings/apis
# In test mode use your test secret key (starts with FLWSECK_TEST-)
# In production use your live secret key (starts with FLWSECK-)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_key_here

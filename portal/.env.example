# URL of the store-backend Express server (internal — not public)
STORE_BACKEND_URL=http://localhost:3001

# AWS region (used to verify Cognito JWT issuer on admin routes)
AWS_REGION=us-east-1

# Cognito user pool ID (used for JWT iss validation on admin routes)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

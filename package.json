{
  "name": "agron-project",
  "version": "1.0.0",
  "description": "AGRON - AI Powered Crop Health Companion",
  "main": "agrof-main/mobile/app/index.js",
  "scripts": {
    "start": "cd agrof-main/mobile/app && npx expo start",
    "start:mobile": "cd agrof-main/mobile/app && npx expo start --port 8086",
    "start:backend": "cd agrof-main/src && python -m flask run --port 5000",
    "start:store": "cd store-backend && npm start",
    "sandbox": "node_modules/.bin/dotenv -e .env -- npx ampx sandbox",
    "sandbox:once": "node_modules/.bin/dotenv -e .env -- npx ampx sandbox --once",
    "deploy:backend": "node scripts/run-pipeline-deploy.mjs",
    "amplify:outputs": "node scripts/run-generate-outputs.mjs",
    "amplify:copy-outputs": "sh -c 'test -f amplify_outputs.json && cp -f amplify_outputs.json agrof-main/mobile/app/amplify_outputs.json && echo Copied amplify_outputs.json to Expo app || echo \"No amplify_outputs.json at repo root — run npm run deploy:backend or npm run amplify:outputs\"'",
    "verify:amplify": "node scripts/verify-amplify-outputs.js",
    "verify:cognito": "node scripts/verify-cognito-auth-flows.js",
    "test:cognito-login": "node scripts/smoke-test-cognito-login.mjs",
    "enable:user-password-auth": "node scripts/enable-user-password-auth-on-client.js",
    "install:deps": "npm install --no-audit --no-fund"
  },
  "keywords": [
    "agriculture",
    "ai",
    "crop-health",
    "disease-detection"
  ],
  "author": "AGRON Team",
  "license": "MIT",
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@aws-sdk/client-cognito-identity-provider": "^3.787.0",
    "@aws-sdk/client-s3": "^3.787.0",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.250.0",
    "constructs": "^10.6.0"
  }
}

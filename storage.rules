rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can upload and manage their own profile photos
    match /profile-photos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow public read access for store product images
    match /store-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}


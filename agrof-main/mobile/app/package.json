{
  "name": "crop-disease-detector-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx react-native start --port 8086",
    "start:expo": "npx expo start --port 8086",
    "start:metro": "npx metro start --port 8086",
    "android": "npx react-native run-android",
    "ios": "npx react-native run-ios",
    "web": "npx expo start --web",
    "build": "npx expo export --platform web",
    "build:web": "npx expo export --platform web --output-dir dist"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.3.3",
    "@expo/cli": "^54.0.8",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/cli": "^20.0.2",
    "@react-native-community/datetimepicker": "^8.4.5",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-firebase/app": "^23.4.0",
    "@react-native-firebase/auth": "^23.4.0",
    "@react-native-firebase/firestore": "^23.4.0",
    "@react-native-firebase/storage": "^23.4.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@supabase/auth-js": "^2.75.0",
    "@supabase/functions-js": "^2.75.0",
    "@supabase/postgrest-js": "^2.75.0",
    "@supabase/realtime-js": "^2.75.0",
    "@supabase/storage-js": "^2.75.0",
    "@supabase/supabase-js": "^2.75.0",
    "amazon-cognito-identity-js": "^6.3.15",
    "aws-amplify": "^6.16.4",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.0",
    "expo-av": "~16.0.7",
    "expo-constants": "~18.0.9",
    "expo-file-system": "~19.0.14",
    "expo-font": "~14.0.8",
    "expo-image-picker": "^17.0.8",
    "expo-localization": "~17.0.7",
    "expo-location": "~19.0.7",
    "expo-sensors": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "~29.0.11",
    "firebase": "^12.4.0",
    "i18next": "^23.16.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^13.5.0",
    "react-native": "0.81.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-paper": "^5.11.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "serve": "^14.2.5",
    "victory-native": "^41.20.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native/metro-config": "^0.81.0"
  },
  "private": true,
  "expo": {
    "name": "Crop Disease Detector",
    "slug": "crop-disease-detector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cropai.detectordisease"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.cropai.detectordisease",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "extra": {
      "API_URL": "https://agrof.farm/api"
    }
  }
}
